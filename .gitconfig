[user]
	email = jackson.hardaker@gmail.com
	name = Jackson Hardaker
[core]
	editor = vim
	pager = delta
[alias]
	d = branch -D
	rb = reset --soft \"HEAD^\"
	co = checkout
	cob = checkout -b
	cp = cherry-pick
	ca = !git add -A && git commit
	lg = log --color --graph --pretty=format:'%Cred%h%Creset %C(bold blue)<%an>%Creset %Cgreen%ad -%C(yellow)%d%Creset %s' --date=local --abbrev-commit --branches
	prb = pull --rebase origin main

[delta]
    plus-color = "#012800"
    minus-color = "#340001"
    syntax-theme = Monokai Extended

[interactive]
    diffFilter = delta --color-only
[init]
	defaultBranch = main
